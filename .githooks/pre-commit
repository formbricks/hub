#!/bin/bash

# Git pre-commit hook to enforce code formatting and linting
# This hook runs before each commit to ensure code quality

set -e

# Add Go bin directories to PATH (git hooks run in minimal environment)
export PATH="$HOME/go/bin:${GOPATH:-$HOME/go}/bin:$PATH"

echo "Running pre-commit checks..."

# Check if golangci-lint is installed
if ! command -v golangci-lint >/dev/null 2>&1; then
    echo "Error: golangci-lint not found. Install it with: make install-tools"
    exit 1
fi

# Validate migrations if any staged file is in migrations/
STAGED_MIGRATIONS=$(git diff --cached --name-only --diff-filter=ACM | grep '^migrations/' || true)
if [ -n "$STAGED_MIGRATIONS" ]; then
    echo "Validating migration files..."
    if ! command -v goose >/dev/null 2>&1; then
        echo "Error: goose not found. Install it with: make install-tools"
        exit 1
    fi
    if ! make migrate-validate; then
        echo ""
        echo "❌ Migration validation failed. Fix the errors above before committing."
        exit 1
    fi
fi

# Format code (make fmt = gofumpt + gci via golangci-lint --fix from .golangci.yml)
# Keep track of staged Go files so we only auto-stage fixes for those files.
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
echo "Running make fmt..."
if ! make fmt; then
    echo ""
    echo "❌ Format failed. Fix the errors above, then run: git add -u && git commit"
    exit 1
fi

# Stage only auto-fixed files that were already staged.
if [ -n "$STAGED_GO_FILES" ]; then
    FIXED_FILES=""
    for file in $STAGED_GO_FILES; do
        if git diff --name-only -- "$file" | grep -q .; then
            git add -- "$file"
            FIXED_FILES="${FIXED_FILES}${FIXED_FILES:+$'\n'}${file}"
        fi
    done
    if [ -n "$FIXED_FILES" ]; then
        echo "Staging auto-fixed files..."
        echo "$FIXED_FILES" | sed 's/^/    /'
    fi
fi

# Verify no remaining issues
echo "Running linter..."
if ! make lint; then
    echo ""
    echo "❌ Linting failed. Please fix the errors above before committing."
    exit 1
fi

# Fast unit tests (no DB)
echo "Running unit tests..."
if ! make test-unit; then
    echo ""
    echo "❌ Unit tests failed. Fix the errors above before committing."
    exit 1
fi

# Coverage check only for packages with staged production code (not just *_test.go) — each must have at least PRE_COMMIT_COVERAGE_THRESHOLD%
if [ -n "$STAGED_GO_FILES" ]; then
    MODULE=$(go list -m)
    STAGED_PACKAGES=""
    for f in $STAGED_GO_FILES; do
        case "$f" in
            internal/*|pkg/*|tests/*)
                [[ "$f" == *_test.go ]] && continue
                dir=$(dirname "$f")
                pkg="${MODULE}/${dir}"
                if [[ " $STAGED_PACKAGES " != *" $pkg "* ]]; then
                    STAGED_PACKAGES="${STAGED_PACKAGES} ${pkg}"
                fi
                ;;
        esac
    done
    if [ -n "$STAGED_PACKAGES" ]; then
        echo "Running coverage check for staged packages..."
        if ! STAGED_PACKAGES="$STAGED_PACKAGES" make check-coverage-staged; then
            echo ""
            echo "❌ Staged packages have insufficient coverage. Add tests or adjust PRE_COMMIT_COVERAGE_THRESHOLD."
            exit 1
        fi
    fi
fi

echo "✅ Pre-commit checks passed!"
exit 0
